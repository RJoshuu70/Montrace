<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_cream">

    <!-- Header: Logo + Tanggal -->
    <RelativeLayout
        android:id="@+id/layout_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/sys_navy_500"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <!-- Logo -->
        <ImageView
            android:id="@+id/iv_profile_placeholder"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:src="@drawable/logo_notext"
            android:contentDescription="Logo Aplikasi"
            android:scaleType="fitCenter" />

        <!-- Nama Halaman (Tengah) -->
        <TextView
            android:id="@+id/tv_title_transaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="TRANSACTION"
            android:textColor="@color/text_white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:letterSpacing="0.1" />

        <!-- Tanggal -->
        <TextView
            android:id="@+id/tv_date_transaction"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:text="30 Juni\n2026"
            android:textColor="@color/text_white"
            android:textSize="14sp"
            android:gravity="end"
            android:textStyle="bold"
            android:lineSpacingMultiplier="1.2" />
    </RelativeLayout>

    <!-- Filters Section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp">

        <!-- Filter bulan dan kategori -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <!-- Filter: Month -->
            <RelativeLayout
                android:id="@+id/btn_filter_month"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">

                <TextView
                    android:id="@+id/tv_filter_month"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/iv_filter_month"
                    android:text="All"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/iv_filter_month"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Filter bulan" />
            </RelativeLayout>

            <!-- Filter: All -->
            <RelativeLayout
                android:id="@+id/btn_filter_all"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:background="@drawable/bg_filter_chip"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginStart="10dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:layout_toStartOf="@+id/iv_filter_all"
                    android:text="All"
                    android:textColor="@color/text_primary"
                    android:textSize="13sp" />

                <ImageView
                    android:id="@+id/iv_filter_all"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_dropdown"
                    android:contentDescription="Filter semua" />
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- List Transaksi -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_transactions"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

        <TextView
            android:id="@+id/tv_no_data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="Tidak ada data yang ditemukan."
            android:textSize="15sp"
            android:textColor="#A6B4E5"
            android:visibility="gone" />
    </FrameLayout>
</LinearLayout>