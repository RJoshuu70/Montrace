<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_cream">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header: Logo + Tanggal -->
        <RelativeLayout
            android:id="@+id/layout_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/sys_navy_500"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- Logo -->
            <ImageView
                android:id="@+id/iv_profile_placeholder"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/logo_notext"
                android:contentDescription="Logo Aplikasi"
                android:scaleType="fitCenter" />

            <!-- Nama Halaman (Tengah) -->
            <TextView
                android:id="@+id/tv_title_about"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:text="ABOUT"
                android:textColor="@color/text_white"
                android:textSize="16sp"
                android:textStyle="bold"
                android:letterSpacing="0.1" />

            <!-- Tanggal -->
            <TextView
                android:id="@+id/tv_date_about"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="30 Juni\n2026"
                android:textColor="@color/text_white"
                android:textSize="14sp"
                android:gravity="end"
                android:textStyle="bold"
                android:lineSpacingMultiplier="1.2" />
        </RelativeLayout>

        <!-- Container dengan Padding Samping agar Posisi Kartu Sejajar Rapi -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="32dp"
            android:paddingBottom="80dp">

            <!-- Bagian Judul Kelompok -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Group 5"
                android:textColor="@color/sys_navy_900"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:text="Pemrograman Aplikasi Bergerak"
                android:textColor="@color/sys_navy_900"
                android:textSize="14sp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="24dp" />

            <!-- Daftar Card Anggota -->

            <!-- Anggota 1: Joshua -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_member_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9">

                    <ImageView
                        android:id="@+id/iv_member_photo_1"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/joshua"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Joshua" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rapolo Joshua Napitupulu"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2410512001"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/btn_instagram_1"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="Instagram"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_linkedin_1"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="LinkedIn"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Anggota 2: Rafi -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_member_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9">

                    <ImageView
                        android:id="@+id/iv_member_photo_2"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/rafi"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Rafi" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rafi Fauzi Alfariz"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2410512015"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/btn_instagram_2"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="Instagram"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/btn_linkedin_2"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="LinkedIn"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Anggota 3: Torikh -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_member_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9">

                    <ImageView
                        android:id="@+id/iv_member_photo_3"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/torikh"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Torikh" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Torikh Abdullah Naser"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2410512031"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/btn_instagram_3"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="Instagram"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btn_linkedin_3"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="LinkedIn"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Anggota 4: Fani -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_member_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9">

                    <ImageView
                        android:id="@+id/iv_member_photo_4"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/fani"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Fani"/>
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fani Dwi Ariyanti"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2410512053"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/btn_instagram_4"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="Instagram"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btn_linkedin_4"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="LinkedIn"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- Anggota 5: Damar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:background="@drawable/bg_member_card"
                android:padding="12dp"
                android:layout_marginBottom="16dp"
                android:gravity="center_vertical">

                <androidx.cardview.widget.CardView
                    android:layout_width="72dp"
                    android:layout_height="72dp"
                    app:cardCornerRadius="8dp"
                    app:cardElevation="0dp"
                    app:cardBackgroundColor="#D9D9D9">

                    <ImageView
                        android:id="@+id/iv_member_photo_5"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:src="@drawable/damar"
                        android:scaleType="centerCrop"
                        android:contentDescription="Foto Damar" />
                </androidx.cardview.widget.CardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Damar Kusumawardhani"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="2410512069"
                        android:textColor="@color/sys_navy_900"
                        android:textSize="13sp"
                        android:layout_marginTop="2dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/btn_instagram_5"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="Instagram"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginEnd="6dp"
                            android:clickable="true"
                            android:focusable="true"/>

                        <TextView
                            android:id="@+id/btn_linkedin_5"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_social_button"
                            android:text="LinkedIn"
                            android:textColor="@color/sys_navy_900"
                            android:gravity="center"
                            android:textSize="12sp"
                            android:layout_marginStart="6dp"
                            android:clickable="true"
                            android:focusable="true"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Tombol Logout -->
        <Button
            android:id="@+id/btn_logout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:text="Logout"
            android:textColor="@color/text_white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:backgroundTint="@color/sys_navy_500"
            android:stateListAnimator="@null" />

    </LinearLayout>
</ScrollView>